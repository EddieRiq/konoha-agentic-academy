    "provider",
    "model",
    "exit_code",
    "success"
  ],
  "properties": {
    "report_type": {
      "const": "local_model_download_report"
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "success": {
