{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "all_candidate_issues": {
      "type": "array"
    },
    "deterministic_markers": {
      "type": "object"
    },
    "heuristic_issues": {
      "type": "array"
    },
    "inconsistencies": {
      "description": "Backward-compatible list of validated/actionable issues only.",
      "type": "array"
    },
    "model": {
      "type": "string"
    },
    "model_suggested_issues": {
      "type": "array"
    },
    "provider": {
      "type": "string"
    },
    "report_type": {
      "const": "local_repo_consistency_audit"
    },
    "status": {
      "enum": [
        "needs_human_review",
        "no_validated_inconsistencies_found",
        "no_obvious_inconsistencies_found"
      ],
      "type": "string"
    },
    "suppressed_issues": {
      "type": "array"
    },
    "usage": {
      "type": "object"
    },
    "validated_issues": {
      "type": "array"
    }
  },
  "required": [
    "report_type",
    "provider",
    "model",
    "inconsistencies",
    "usage",
    "authority"
  ],
  "title": "Local Repo Consistency Audit with Deterministic Guard",
  "type": "object"
}