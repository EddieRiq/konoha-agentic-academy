{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha-agentic-academy.local/schemas/runtime/local_village_config.schema.json",
  "title": "Konoha Local Village Config",
  "type": "object",
  "required": [
    "schema_version",
    "village_name",
    "village_type",
    "generated_at",
    "village_root",
    "memory",
    "assets",
    "local_profile",
    "permissions",
    "authority",
    "boundaries"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "village_name": { "type": "string" },
    "village_type": { "const": "local_private_village" },
    "generated_at": { "type": "string" },
    "village_root": { "type": "string" },
    "language_policy": { "type": "object" },
    "memory": { "type": "object" },
    "assets": { "type": "object" },
    "local_profile": { "type": "object" },
    "permissions": { "type": "object" },
    "authority": { "type": "object" },
    "boundaries": { "type": "object" }
  },
  "additionalProperties": true
}
