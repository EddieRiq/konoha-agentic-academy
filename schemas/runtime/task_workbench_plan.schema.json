{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha.local/schemas/runtime/task_workbench_plan.schema.json",
  "title": "General Task Workbench Plan",
  "type": "object",
  "required": [
    "schema_version",
    "plan_id",
    "mission_id",
    "task",
    "task_domain",
    "target_environment",
    "phases",
    "authority",
    "boundaries"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "plan_id": { "type": "string" },
    "mission_id": { "type": "string" },
    "task": { "type": "string" },
    "task_domain": { "type": "string" },
    "target_environment": { "type": "string" },
    "risk_level": { "type": "string" },
    "privacy_level": { "type": "string" },
    "approval_mode": { "type": "string" },
    "generated_at": { "type": "string" },
    "playbook": { "type": "object" },
    "phases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "authority": { "type": "object" },
    "boundaries": { "type": "object" }
  },
  "additionalProperties": true
}
