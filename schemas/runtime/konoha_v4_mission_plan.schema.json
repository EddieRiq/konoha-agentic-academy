{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Konoha v4 Mission Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "understanding",
    "explicit_facts",
    "missing_context",
    "assumptions_prohibited",
    "complexity",
    "assignments",
    "acceptance_criteria",
    "approval_boundaries",
    "estimated_tokens",
    "estimated_cost_class",
    "rationale",
    "approval",
    "teachback_policy",
    "workspace_policy",
    "budget",
    "governance"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "pattern": "^mission-[a-z0-9-]+$"
    },
    "understanding": {
      "type": "string",
      "minLength": 10
    },
    "explicit_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions_prohibited": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "complexity": {
      "enum": [
        "low",
        "medium",
        "high",
        "strategic"
      ],
      "type": "string"
    },
    "assignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "family",
          "provider",
          "model",
          "objective",
          "inputs",
          "expected_output",
          "dependencies",
          "private_context",
          "network",
          "mutation",
          "estimated_input_tokens",
          "estimated_output_tokens",
          "estimated_total_tokens",
          "cost_class",
          "fallback",
          "stop_condition"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "provider": {
            "enum": [
              "codex",
              "claude",
              "ollama"
            ],
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_output": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "private_context": {
            "type": "boolean"
          },
          "network": {
            "type": "boolean"
          },
          "mutation": {
            "type": "boolean"
          },
          "estimated_input_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "estimated_output_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "estimated_total_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "cost_class": {
            "enum": [
              "local",
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "fallback": {
            "type": "string",
            "minLength": 1
          },
          "stop_condition": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "approval_boundaries": {
      "type": "array",
      "items": {
        "enum": [
          "read_only",
          "private_context",
          "network",
          "mutation",
          "git",
          "instruction_change",
          "budget_overage"
        ],
        "type": "string"
      }
    },
    "estimated_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "estimated_cost_class": {
      "enum": [
        "local",
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "approved_by",
        "approved_at",
        "feedback"
      ],
      "properties": {
        "status": {
          "enum": [
            "pending",
            "approved",
            "rejected",
            "changes_requested"
          ],
          "type": "string"
        },
        "approved_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "approved_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "feedback": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "teachback_policy": {
      "enum": [
        "disabled",
        "optional",
        "required"
      ],
      "type": "string"
    },
    "workspace_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_mutation_allowed",
        "private_runtime_state_allowed",
        "private_state_root"
      ],
      "properties": {
        "workspace_mutation_allowed": {
          "type": "boolean",
          "const": false
        },
        "private_runtime_state_allowed": {
          "type": "boolean"
        },
        "private_state_root": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_totals",
        "family_totals",
        "replanning_reserve_tokens",
        "maximum_total_tokens"
      ],
      "properties": {
        "provider_totals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "provider",
              "total_tokens"
            ],
            "properties": {
              "provider": {
                "type": "string",
                "enum": [
                  "codex",
                  "claude",
                  "ollama"
                ]
              },
              "total_tokens": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "family_totals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "family",
              "total_tokens"
            ],
            "properties": {
              "family": {
                "type": "string",
                "minLength": 1
              },
              "total_tokens": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "replanning_reserve_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "maximum_total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conductor",
        "constitutional_authority"
      ],
      "properties": {
        "conductor": {
          "const": "codex",
          "type": "string"
        },
        "constitutional_authority": {
          "const": "hokage",
          "type": "string"
        }
      }
    }
  }
}
