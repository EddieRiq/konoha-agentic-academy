{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha.local/schemas/runtime/model_provider_validation_report.schema.json",
  "title": "Konoha Model Provider Validation Report",
  "type": "object",
  "required": [
    "report_type",
    "status",
    "checks",
    "blockers",
    "human_review_required"
  ],
  "properties": {
    "report_type": {
      "const": "model_provider_contract_validation"
    },
    "contract_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "request_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "purpose": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "checks": {
      "type": "object"
    },
    "limits": {
      "type": "object"
    },
    "request_budget": {
      "type": "object"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_required": {
      "type": "boolean"
    },
    "approval_token_required_for_future_invocation": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}