{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Konoha Git Operation Plan",
  "type": "object",
  "required": [
    "schema_version",
    "plan_type",
    "plan_id",
    "repo_root",
    "paths",
    "commit_message",
    "authority",
    "boundaries"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "plan_type": {
      "const": "git_operation_plan"
    },
    "plan_id": {
      "type": "string"
    },
    "repo_root": {
      "type": "string"
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remote": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "commit_message": {
      "type": "string"
    },
    "read_only_git_evidence": {
      "type": "object"
    },
    "required_sequence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority": {
      "type": "object"
    },
    "boundaries": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
