{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha-agentic-academy.local/schemas/runtime/runtime_package_index.schema.json",
  "title": "Runtime Package Index",
  "description": "Runtime Package Index contract for Konoha dry-run runtime artifacts.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "artifact_type",
    "package_id",
    "mission_id",
    "artifacts"
  ],
  "properties": {
    "artifact_type": {
      "const": "runtime_package_index"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_type",
          "reference"
        ],
        "properties": {
          "artifact_type": {
            "type": "string",
            "minLength": 1
          },
          "reference": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "present",
              "missing",
              "superseded",
              "blocked"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "trace_references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
