{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha-agentic-academy.local/schemas/runtime/scroll_lifecycle_index.schema.json",
  "title": "Scroll Lifecycle Index",
  "type": "object",
  "required": [
    "schema_version",
    "index_type",
    "generated_at",
    "mission_id",
    "proposal_count",
    "proposals",
    "authority",
    "boundaries"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "index_type": { "type": "string" },
    "generated_at": { "type": "string" },
    "mission_id": { "type": "string" },
    "proposal_count": { "type": "integer", "minimum": 0 },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposal_id", "scroll_name", "lifecycle_state", "path"],
        "properties": {
          "proposal_id": { "type": "string" },
          "scroll_name": { "type": "string" },
          "lifecycle_state": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "authority": { "type": "object" },
    "boundaries": { "type": "object" }
  },
  "additionalProperties": true
}
