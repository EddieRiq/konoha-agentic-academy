{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conversational Mission Charter",
  "type": "object",
  "required": [
    "schema_version",
    "report_type",
    "charter_id",
    "created_at",
    "actor",
    "objective",
    "scope",
    "out_of_scope",
    "constraints",
    "risk_level",
    "proposed_skills",
    "approval_gates",
    "success_criteria",
    "state",
    "approval_phrase",
    "rejection_phrase",
    "authority"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "report_type": {
      "const": "conversational_mission_charter"
    },
    "charter_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "out_of_scope": {
      "type": "array"
    },
    "constraints": {
      "type": "array"
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "proposed_skills": {
      "type": "array"
    },
    "approval_gates": {
      "type": "array"
    },
    "success_criteria": {
      "type": "array"
    },
    "state": {
      "enum": [
        "proposed",
        "approved",
        "rejected"
      ]
    },
    "approval_phrase": {
      "type": "string"
    },
    "rejection_phrase": {
      "type": "string"
    },
    "authority": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
