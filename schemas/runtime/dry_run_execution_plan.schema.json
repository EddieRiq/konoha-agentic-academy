{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha-agentic-academy.local/schemas/runtime/dry_run_execution_plan.schema.json",
  "title": "Dry Run Execution Plan",
  "description": "Dry Run Execution Plan contract for Konoha dry-run runtime artifacts.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "artifact_type",
    "mission_id",
    "mode",
    "plan_summary",
    "steps",
    "safety_flags"
  ],
  "properties": {
    "artifact_type": {
      "const": "dry_run_execution_plan"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "const": "dry_run"
    },
    "plan_summary": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "description",
          "action_type",
          "execution_allowed"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "action_type": {
            "enum": [
              "inspect",
              "validate",
              "plan",
              "review",
              "report",
              "other"
            ]
          },
          "execution_allowed": {
            "const": false
          },
          "expected_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shell_execution",
        "filesystem_mutation",
        "git_operations",
        "adapter_execution",
        "private_context_access",
        "autonomous_execution"
      ],
      "properties": {
        "shell_execution": {
          "const": false
        },
        "filesystem_mutation": {
          "const": false
        },
        "git_operations": {
          "const": false
        },
        "adapter_execution": {
          "const": false
        },
        "private_context_access": {
          "const": false
        },
        "autonomous_execution": {
          "const": false
        }
      }
    }
  }
}
