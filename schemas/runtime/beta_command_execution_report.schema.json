      "type": "object"
    },
    "command": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "mission_id": {
      "type": "string"
    },
    "report_type": {
      "const": "beta_command_execution_report"
    },
    "result_id": {
      "type": "string"
    },
    "schema_version": {
