{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha.local/schemas/runtime/mission_approval_event.schema.json",
  "title": "Konoha Mission Approval Event",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "event_id",
    "mission_id",
    "event_type",
    "transition",
    "decision",
    "reason",
    "actor",
    "created_at_utc",
    "approval_token_verified",
    "safety_boundaries"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "tool": {
      "const": "human_approval_console_cli"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "approval",
        "rejection"
      ]
    },
    "transition": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "approval_token_verified": {
      "type": "boolean"
    },
    "review_required_after_event": {
      "type": "boolean"
    },
    "safety_boundaries": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
