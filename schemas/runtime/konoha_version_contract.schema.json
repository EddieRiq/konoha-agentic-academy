{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Konoha Version Contract",
  "type": "object",
  "required": [
    "schema_version",
    "report_type",
    "status",
    "values",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "report_type": {
      "const": "konoha_version_contract"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "values": {
      "type": "object"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
