{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Konoha User Continuity",
  "type": "object",
  "required": [
    "schema_version",
    "report_type",
    "actor",
    "first_seen_at",
    "last_session_at",
    "session_count",
    "last_mission_id",
    "active_mission_id",
    "last_handoff",
    "authority"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "report_type": {
      "const": "konoha_user_continuity"
    },
    "actor": {
      "type": "string"
    },
    "first_seen_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_session_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "session_count": {
      "type": "integer",
      "minimum": 0
    },
    "last_mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "active_mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_handoff": {
      "type": [
        "string",
        "null"
      ]
    },
    "authority": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
