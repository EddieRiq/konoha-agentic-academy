{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://konoha.local/schemas/doctrine/constitutional_metadata.schema.json",
  "title": "Konoha Constitutional Registry",
  "type": "object",
  "required": [
    "schema_version",
    "registry_type",
    "supreme_authority",
    "documents",
    "roles",
    "invariants"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "registry_type": {
      "const": "konoha_constitutional_registry"
    },
    "supreme_authority": {
      "type": "string",
      "const": "core/laws/KONOHA_LAWS.md"
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "authority_level",
          "document_type"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "authority_level": {
            "type": "integer",
            "minimum": 1
          },
          "document_type": {
            "enum": [
              "constitution",
              "conduct",
              "protocol",
              "role_policy",
              "architecture"
            ]
          },
          "role": {
            "type": [
              "string",
              "null"
            ]
          },
          "normative": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "policy_path",
          "may_decide_strategy",
          "may_execute",
          "may_review_own_work",
          "may_self_approve",
          "may_modify_own_policy",
          "may_approve_doctrine"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "policy_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "may_decide_strategy": {
            "type": "boolean"
          },
          "may_execute": {
            "type": "boolean"
          },
          "may_review_own_work": {
            "type": "boolean"
          },
          "may_self_approve": {
            "type": "boolean"
          },
          "may_modify_own_policy": {
            "type": "boolean"
          },
          "may_approve_doctrine": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "invariants": {
      "type": "object",
      "required": [
        "memory_is_evidence_only",
        "model_output_is_evidence_only",
        "mission_charter_cannot_expand_authority",
        "providers_do_not_decide_strategy",
        "git_gates_are_separate"
      ],
      "properties": {
        "memory_is_evidence_only": {
          "const": true
        },
        "model_output_is_evidence_only": {
          "const": true
        },
        "mission_charter_cannot_expand_authority": {
          "const": true
        },
        "providers_do_not_decide_strategy": {
          "const": true
        },
        "git_gates_are_separate": {
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
